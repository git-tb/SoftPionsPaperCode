Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"u*(t,p)==1 at v1(t,p)=\"\>", "\[InvisibleSpace]", 
   FractionBox[
    RowBox[{
     RowBox[{
      RowBox[{"-", "Eabc"}], " ", "ma"}], "+", 
