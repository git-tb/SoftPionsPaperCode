      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", 
         SuperscriptBox["Eabc", "2"]}], "+", 
        SuperscriptBox["mb", "2"], "+", 
        SuperscriptBox["p", "2"]}], ")"}]}]], 
    RowBox[{"Eabc", " ", "Q"}]], "\[InvisibleSpace]", "\<\" and v1=\"\>", 
   "\[InvisibleSpace]", 
   FractionBox[
    SqrtBox[
     RowBox[{
      RowBox[{"-", 
       SuperscriptBox["Eabc", "2"]}], "+", 
      SuperscriptBox["mb", "2"], "+", 
      SuperscriptBox["p", "2"]}]], "p"]}],
  SequenceForm[
  "Lower Bound of v-integration given by:\tminimum of v1(t,p) at t=", \
$CellContext`Eabc^(-1) ($CellContext`ma^2 (-$CellContext`Eabc^2 + \
$CellContext`mb^2 + $CellContext`p^2))^Rational[1, 2]/$CellContext`Q, 
   " and v1=", $CellContext`p^(-1) (-$CellContext`Eabc^2 + $CellContext`mb^2 + \
$CellContext`p^2)^Rational[1, 2]],
  Editable->False]], "Print",
