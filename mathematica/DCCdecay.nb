Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", 
   RowBox[{"ma", ",", "mb", ",", "mc", ",", "Eabc", ",", "B", ",", "Q"}], 
   "]"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"w", "[", 
    RowBox[{"p_", ",", "m_"}], "]"}], "=", 
   SqrtBox[
    RowBox[{
     RowBox[{"p", "^", "2"}], "+", 
     RowBox[{"m", "^", "2"}]}]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ustar", "[", 
    RowBox[{"t_", ",", "v_"}], "]"}], "=", 
   FractionBox[
    RowBox[{
     RowBox[{"ma", "*", "Eabc"}], "+", 
     RowBox[{"t", "*", "v", "*", "Q", "*", "p"}]}], 
    RowBox[{
     RowBox[{"w", "[", 
      RowBox[{
       RowBox[{"t", "*", "Q"}], ",", "ma"}], "]"}], "*", 
     RowBox[{"w", "[", 
      RowBox[{"p", ",", "mb"}], "]"}]}]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"myassumptions", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Element", "[", 
      RowBox[{"ma", ",", "Reals"}], "]"}], ",", 
     RowBox[{"ma", ">", "0"}], ",", 
     RowBox[{"Element", "[", 
      RowBox[{"Eabc", ",", "Reals"}], "]"}], ",", 
     RowBox[{"Eabc", ">", "0"}], ",", 
     RowBox[{"Element", "[", 
      RowBox[{"Q", ",", "Reals"}], "]"}], ",", 
     RowBox[{"Q", ">", "0"}]}], "}"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"s", "=", 
   RowBox[{"Solve", "[", 
    RowBox[{
     RowBox[{"1", "==", 
      RowBox[{"ustar", "[", 
       RowBox[{"t", ",", "v"}], "]"}]}], ",", "v"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"v1", "[", 
    RowBox[{"t_", ",", "p_"}], "]"}], "=", 
   RowBox[{
    RowBox[{"v", "/.", 
     RowBox[{"s", "[", 
      RowBox[{"[", "1", "]"}], "]"}]}], "//", "FullSimplify"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"t1min", "[", "p_", "]"}], "=", 
   RowBox[{
    RowBox[{"t", "/.", 
     RowBox[{
      RowBox[{"Solve", "[", 
       RowBox[{
        RowBox[{"0", "==", 
         RowBox[{"D", "[", 
          RowBox[{
           RowBox[{"v1", "[", 
            RowBox[{"t", ",", "p"}], "]"}], ",", "t"}], "]"}]}], ",", "t"}], 
       "]"}], "[", 
      RowBox[{"[", "2", "]"}], "]"}]}], "//", "FullSimplify"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"vmin", "[", "p_", "]"}], "=", 
   RowBox[{
    RowBox[{"v1", "[", 
     RowBox[{
      RowBox[{"t1min", "[", "p", "]"}], ",", "p"}], "]"}], "//", 
    "FullSimplify"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"s2", "=", 
   RowBox[{
    RowBox[{"Solve", "[", 
     RowBox[{
      RowBox[{"1", "==", 
       RowBox[{"v1", "[", 
        RowBox[{"t", ",", "p"}], "]"}]}], ",", "t"}], "]"}], "//", 
    "FullSimplify"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"tmin", "[", "p_", "]"}], "=", 
   RowBox[{
    RowBox[{"t", "/.", 
     RowBox[{"s2", "[", 
      RowBox[{"[", "1", "]"}], "]"}]}], "//", "FullSimplify"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"tmax", "[", "p_", "]"}], "=", 
   RowBox[{
    RowBox[{"t", "/.", 
     RowBox[{"s2", "[", 
      RowBox[{"[", "2", "]"}], "]"}]}], "//", "FullSimplify"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<u*(t,p)==1 at v1(t,p)=\>\"", ",", 
   RowBox[{"v1", "[", 
    RowBox[{"t", ",", "p"}], "]"}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"Print", "[", 
  RowBox[{
  "\"\<Lower Bound of v-integration given by:\\tminimum of v1(t,p) at t=\>\"",
    ",", 
   RowBox[{"t1min", "[", "p", "]"}], ",", "\"\< and v1=\>\"", ",", 
   RowBox[{
    RowBox[{"vmin", "[", "p", "]"}], "//", 
    RowBox[{
     RowBox[{"FullSimplify", "[", 
      RowBox[{"#", ",", 
       RowBox[{"Assumptions", "->", "myassumptions"}]}], "]"}], "&"}]}]}], 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{"Print", "[", 
  RowBox[{
  "\"\<Lower Bound of t-integration given by:\\tv1(t,p)=+1 at tmin(p)=\>\"", 
   ",", 
   RowBox[{
    RowBox[{"tmin", "[", "p", "]"}], "//", 
    RowBox[{
     RowBox[{"FullSimplify", "[", 
      RowBox[{"#", ",", 
       RowBox[{"Assumptions", "->", "myassumptions"}]}], "]"}], "&"}]}]}], 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{
   "\"\<Upper Bound of t-integration given by:\\tv1(t,p)=+1 at tmax(p)=\>\"", 
    ",", 
    RowBox[{
     RowBox[{"tmax", "[", "p", "]"}], "//", 
     RowBox[{
      RowBox[{"FullSimplify", "[", 
       RowBox[{"#", ",", 
        RowBox[{"Assumptions", "->", "myassumptions"}]}], "]"}], "&"}]}]}], 
   "]"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"Clear", "[", 
  RowBox[{
  "w", ",", "ustar", ",", "g", ",", "s", ",", "v1", ",", "t1min", ",", "vmin",
    ",", "s2", ",", "tmin", ",", "tmax"}], "]"}]}], "Input",
