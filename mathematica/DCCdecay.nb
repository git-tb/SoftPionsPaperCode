Cell["\<\
...and choose one file for testing. We need the primary spectrum as an \
interpolated function and the decay parameters (masses) to perform the \
computation.\
\>", "Text",
 CellFrame->{{0, 0}, {0, 0}},
 CellChangeTimes->{{3.946379627523232*^9, 3.946379731082754*^9}, {
  3.9463798463265877`*^9, 3.946379851234219*^9}, {3.9580411229374247`*^9, 
  3.958041130874216*^9}},
 Background->RGBColor[
  1, 0.9, 0.8],ExpressionUUID->"565e1078-d3be-4206-9dcd-d95ba8ad9cad"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"cppspecfolder", "=", 
   RowBox[{"folders", "[", 
    RowBox[{"[", "280", "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"dataprimespec", "=", 
   RowBox[{"Import", "[", 
    RowBox[{
     RowBox[{"StringJoin", "[", 
      RowBox[{"cppspecfolder", ",", "\"\</primespec.txt\>\""}], "]"}], ",", 
     "\"\<CSV\>\""}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"datadecayspec", "=", 
    RowBox[{"Import", "[", 
     RowBox[{
      RowBox[{"StringJoin", "[", 
       RowBox[{"cppspecfolder", ",", "\"\</decayspec.txt\>\""}], "]"}], ",", 
      "\"\<CSV\>\""}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"decayspechead", "=", 
  RowBox[{"datadecayspec", "[", 
   RowBox[{"[", 
    RowBox[{"1", ";;", "15"}], "]"}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"Print", "[", 
  RowBox[{
  "\"\<\!\(\*StyleBox[\"primary\",FontWeight->\"Bold\"]\)\!\(\*StyleBox[\" \
\",FontWeight->\"Bold\"]\)\!\(\*StyleBox[\"spec\",FontWeight->\"Bold\"]\)\!\(\
\*StyleBox[\" \
\",FontWeight->\"Bold\"]\)\!\(\*StyleBox[\"header\",FontWeight->\"Bold\"]\)\!\
\(\*StyleBox[\":\",FontWeight->\"Bold\"]\)\\n\>\"", ",", 
   RowBox[{"TableForm", "[", 
    RowBox[{"dataprimespec", "[", 
     RowBox[{"[", 
      RowBox[{"1", ";;", "3"}], "]"}], "]"}], "]"}], ",", 
   "\"\<\\n(...)\>\""}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{
   "\"\<\!\(\*StyleBox[\"decay\",FontWeight->\"Bold\"]\)\!\(\*StyleBox[\" \
\",FontWeight->\"Bold\"]\)\!\(\*StyleBox[\"spec\",FontWeight->\"Bold\"]\)\!\(\
\*StyleBox[\" \
\",FontWeight->\"Bold\"]\)\!\(\*StyleBox[\"header\",FontWeight->\"Bold\"]\)\!\
\(\*StyleBox[\":\",FontWeight->\"Bold\"]\)\\n\>\"", ",", 
    RowBox[{"TableForm", "[", "decayspechead", "]"}], ",", 
    "\"\<\\n(...)\>\""}], "]"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"pTscpp", "=", 
   RowBox[{
    RowBox[{"Transpose", "[", 
     RowBox[{"datadecayspec", "[", 
      RowBox[{"[", 
       RowBox[{"15", ";;"}], "]"}], "]"}], "]"}], "[", 
    RowBox[{"[", "1", "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"qTs", "=", 
   RowBox[{
    RowBox[{"Transpose", "[", 
     RowBox[{"dataprimespec", "[", 
      RowBox[{"[", 
       RowBox[{"3", ";;"}], "]"}], "]"}], "]"}], "[", 
    RowBox[{"[", "1", "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"qTmax", "=", 
   RowBox[{"qTs", "[", 
    RowBox[{"[", 
     RowBox[{"-", "1"}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{
   "\"\<\!\(\*StyleBox[\"qTmax\",FontWeight->\"Bold\"]\):\\n\>\"", ",", 
    "qTmax"}], "]"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"decayspeccpp", "=", 
   RowBox[{
    RowBox[{"Transpose", "[", 
     RowBox[{"datadecayspec", "[", 
      RowBox[{"[", 
       RowBox[{"15", ";;"}], "]"}], "]"}], "]"}], "[", 
    RowBox[{"[", "2", "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"primespeclist", "=", 
    RowBox[{
     RowBox[{"Transpose", "[", 
      RowBox[{"dataprimespec", "[", 
       RowBox[{"[", 
        RowBox[{"3", ";;"}], "]"}], "]"}], "]"}], "[", 
     RowBox[{"[", "2", "]"}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"primespecloglist", "=", 
   RowBox[{"Log", "@", "primespeclist"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"primespeclog", "=", 
   RowBox[{"Interpolation", "[", 
    RowBox[{"Transpose", "@", 
     RowBox[{"{", 
      RowBox[{"qTs", ",", "primespecloglist"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"primespec", "[", "q_", "]"}], "=", 
    RowBox[{"Exp", "[", 
     RowBox[{"primespeclog", "[", "q", "]"}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"ListLogPlot", "[", 
  RowBox[{
   RowBox[{"Transpose", "@", 
    RowBox[{"{", 
     RowBox[{"pTscpp", ",", "decayspeccpp"}], "}"}]}], ",", 
   RowBox[{"PlotLegends", "->", 
    RowBox[{"{", "\"\<decay spectrum C++\>\"", "}"}]}], ",", 
   RowBox[{"PlotStyle", "->", "Blue"}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"Show", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"LogPlot", "[", 
    RowBox[{
     RowBox[{"primespec", "[", "qT", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"qT", ",", "0", ",", "qTmax"}], "}"}], ",", 
     RowBox[{"PlotLegends", "->", 
      RowBox[{"{", "\"\<primary spectrum interpolated\>\"", "}"}]}], ",", 
     RowBox[{"PlotStyle", "->", "Blue"}]}], "]"}], ",", "\[IndentingNewLine]", 
   RowBox[{"ListLogPlot", "[", 
    RowBox[{
     RowBox[{"Transpose", "@", 
      RowBox[{"{", 
       RowBox[{"qTs", ",", "primespeclist"}], "}"}]}], ",", 
     RowBox[{"PlotLegends", "->", 
      RowBox[{"{", "\"\<primary spectrum C++\>\"", "}"}]}], ",", 
     RowBox[{"PlotMarkers", "->", 
      RowBox[{"{", 
       RowBox[{"Automatic", ",", "2"}], "}"}]}], ",", 
     RowBox[{"PlotStyle", "->", "Red"}]}], "]"}]}], "\[IndentingNewLine]", 
  "]"}]}], "Input",
