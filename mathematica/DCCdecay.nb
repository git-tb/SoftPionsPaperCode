Cell[CellGroupData[{

Cell["Perform the full decay computation in Mathematica", "Section",
 CellChangeTimes->{{3.946379869625616*^9, 3.946379876679063*^9}, {
  3.946381404168169*^9, 
  3.94638140564287*^9}},ExpressionUUID->"553ce2be-2e0a-468b-b50f-\
f598786da4af"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Install", "[", 
   RowBox[{"StringJoin", "[", 
    RowBox[{
     RowBox[{"ParentDirectory", "@", 
      RowBox[{"NotebookDirectory", "[", "]"}]}], ",", 
     "\"\</Cuba-4.2.2/Cuhre\>\""}], "]"}], "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ComputeDecaySpec", "[", 
   RowBox[{
   "ps_", ",", "ma_", ",", "mb_", ",", "mc_", ",", "B_", ",", "Q_", ",", 
    "qmax_", ",", "primespec_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "pabc", ",", "Eabc", ",", "w", ",", "absgradg", ",", "ustar", ",", 
      "area", ",", "myintegrand", ",", "tlower", ",", "tupper", ",", "vlower",
       ",", "tmin", ",", "tmax", ",", "vmin", ",", "MyIntegral", ",", 
      "result"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"pabc", "=", 
      RowBox[{
       FractionBox["1", 
        RowBox[{"2", "*", "ma"}]], 
       SqrtBox[
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{"ma", "+", "mb"}], ")"}], "2"], "-", 
           SuperscriptBox["mc", "2"]}], ")"}], "*", 
         RowBox[{"(", 
          RowBox[{
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{"ma", "-", "mb"}], ")"}], "2"], "-", 
           SuperscriptBox["mc", "2"]}], ")"}]}]]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Eabc", "=", 
      SqrtBox[
       RowBox[{
        SuperscriptBox["mb", "2"], "+", 
        SuperscriptBox["pabc", "2"]}]]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"w", "[", 
       RowBox[{"p_", ",", "m_"}], "]"}], "=", 
      SqrtBox[
       RowBox[{
        RowBox[{"p", "^", "2"}], "+", 
        RowBox[{"m", "^", "2"}]}]]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"ustar", "[", 
       RowBox[{"p_", ",", "t_", ",", "v_"}], "]"}], "=", 
      FractionBox[
       RowBox[{
        RowBox[{"ma", "*", "Eabc"}], "+", 
        RowBox[{"t", "*", "v", "*", "Q", "*", "p"}]}], 
       RowBox[{
        RowBox[{"w", "[", 
         RowBox[{
          RowBox[{"t", "*", "Q"}], ",", "ma"}], "]"}], "*", 
        RowBox[{"w", "[", 
         RowBox[{"p", ",", "mb"}], "]"}]}]]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"myintegrand", "[", 
       RowBox[{"p_", ",", "t_", ",", "v_"}], "]"}], "=", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"ustar", "[", 
          RowBox[{"p", ",", "t", ",", "v"}], "]"}], ">", "1"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"t", "*", 
         RowBox[{"primespec", "[", 
          RowBox[{"t", "*", "Q"}], "]"}], "*", 
         FractionBox["1", 
          RowBox[{
           SqrtBox[
            RowBox[{
             SuperscriptBox[
              RowBox[{"ustar", "[", 
               RowBox[{"p", ",", "t", ",", "v"}], "]"}], "2"], "-", "1"}]], 
           "*", 
           SqrtBox[
            RowBox[{"1", "-", 
             SuperscriptBox["v", "2"]}]]}]], "*", 
         FractionBox["1", 
          RowBox[{
           RowBox[{"w", "[", 
            RowBox[{"p", ",", "mb"}], "]"}], "*", 
           RowBox[{"w", "[", 
            RowBox[{
             RowBox[{"t", "*", "Q"}], ",", "ma"}], "]"}]}]]}], ",", "0"}], 
       "]"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"tlower", "[", "p_", "]"}], "=", 
      FractionBox[
       RowBox[{
        RowBox[{"Eabc", "*", " ", "ma", "*", " ", "p"}], "-", 
        RowBox[{"ma", " ", "*", 
         SqrtBox[
          RowBox[{
           RowBox[{"(", 
            RowBox[{"Eabc", "-", "mb"}], ")"}], " ", "*", 
           RowBox[{"(", 
            RowBox[{"Eabc", "+", "mb"}], ")"}], " ", "*", 
           RowBox[{"(", 
            RowBox[{
             SuperscriptBox["mb", "2"], "+", 
             SuperscriptBox["p", "2"]}], ")"}]}]]}]}], 
       RowBox[{
        SuperscriptBox["mb", "2"], " ", "*", "Q"}]]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"tupper", "[", "p_", "]"}], "=", 
      FractionBox[
       RowBox[{
        RowBox[{"Eabc", "*", " ", "ma", "*", " ", "p"}], "+", 
        RowBox[{"ma", " ", "*", 
         SqrtBox[
          RowBox[{
           RowBox[{"(", 
            RowBox[{"Eabc", "-", "mb"}], ")"}], " ", "*", 
           RowBox[{"(", 
            RowBox[{"Eabc", "+", "mb"}], ")"}], " ", "*", 
           RowBox[{"(", 
            RowBox[{
             SuperscriptBox["mb", "2"], "+", 
             SuperscriptBox["p", "2"]}], ")"}]}]]}]}], 
       RowBox[{
        SuperscriptBox["mb", "2"], " ", "*", "Q"}]]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"vlower", "[", "p_", "]"}], "=", 
      FractionBox[
       SqrtBox[
        RowBox[{
         RowBox[{"-", 
          SuperscriptBox["Eabc", "2"]}], "+", 
         SuperscriptBox["mb", "2"], "+", 
         SuperscriptBox["p", "2"]}]], "p"]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"tmin", "[", "p_", "]"}], "=", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"tlower", "[", "p", "]"}], ">", "0"}], ",", 
        RowBox[{"tlower", "[", "p", "]"}], ",", "0"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"tmax", "[", "p_", "]"}], "=", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"tupper", "[", "p", "]"}], "<", 
         RowBox[{"qmax", "/", "Q"}]}], ",", 
        RowBox[{"tupper", "[", "p", "]"}], ",", 
        RowBox[{"qmax", "/", "Q"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"vmin", "[", "p_", "]"}], "=", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Eabc", "^", "2"}], "<", 
         RowBox[{
          RowBox[{"mb", "^", "2"}], "+", 
          RowBox[{"p", "^", "2"}]}]}], ",", 
        RowBox[{"vlower", "[", "p", "]"}], ",", 
        RowBox[{"-", "1"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"MyIntegral", "[", "p_", "]"}], ":=", 
      RowBox[{
       FractionBox[
        RowBox[{"ma", "*", "B", "*", "Q", "*", "Q"}], 
        RowBox[{"\[Pi]", "*", "pabc"}]], "*", 
       RowBox[{
        RowBox[{
         RowBox[{"Cuhre", "[", 
          RowBox[{
           RowBox[{"myintegrand", "[", 
            RowBox[{"p", ",", "t", ",", "v"}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"t", ",", 
             RowBox[{"tmin", "[", "p", "]"}], ",", 
             RowBox[{"tmax", "[", "p", "]"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"v", ",", 
             RowBox[{"vmin", "[", "p", "]"}], ",", "1"}], "}"}], ",", 
           RowBox[{"Verbose", "->", "0"}]}], "]"}], "[", 
         RowBox[{"[", "1", "]"}], "]"}], "[", 
        RowBox[{"[", "1", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"result", "=", 
      RowBox[{"Map", "[", 
       RowBox[{"MyIntegral", ",", "ps"}], "]"}]}], ";", "\[IndentingNewLine]",
      "result"}]}], "\[IndentingNewLine]", "]"}]}]}], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.946375513622485*^9, 3.94637562057373*^9}, 
   3.946375757011272*^9, {3.946375790437182*^9, 3.9463758147731667`*^9}, {
   3.946376801393381*^9, 3.946376801736206*^9}, {3.946376930554072*^9, 
   3.946376932668261*^9}, {3.9580391436775093`*^9, 3.9580391764477873`*^9}, {
   3.958039532284418*^9, 3.9580395939284887`*^9}, {3.958040635381761*^9, 
   3.958040681559864*^9}},
 CellLabel->
  "In[1917]:=",ExpressionUUID->"c5093926-7f7d-4e23-a7d3-d99fc03fe6ca"],

Cell["\<\
You need to copy the decay parameters from above manually for each new \
dataset. Let\[CloseCurlyQuote]s compute on a smaller pT-grid, since this is \
just a test...\
\>", "Text",
