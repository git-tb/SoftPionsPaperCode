 CellChangeTimes->{{3.9463795658332987`*^9, 
  3.946379577681348*^9}},ExpressionUUID->"3229c98e-9e27-4e65-af4f-\
1f3e15c03ae5"],

Cell["Browse the Data folder to find a suitable computation", "Text",
 CellFrame->{{0, 0}, {0, 0}},
 CellChangeTimes->{{3.94637959040128*^9, 3.94637960821388*^9}},
 Background->RGBColor[
  1, 0.9, 0.8],ExpressionUUID->"46f83fe6-960d-433b-bf44-d78ea14b1f87"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"folders", "=", 
   RowBox[{"FileNames", "[", 
    RowBox[{"StringJoin", "[", 
     RowBox[{
      RowBox[{"ParentDirectory", "[", 
       RowBox[{"NotebookDirectory", "[", "]"}], "]"}], ",", 
      "\"\</data/examplescenario/decayspec/*\>\""}], "]"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Print", "[", 
  RowBox[{
   RowBox[{"Length", "[", "folders", "]"}], ",", "\"\< files found\>\""}], 
  "]"}]}], "Input",
 CellChangeTimes->{{3.946131545317235*^9, 3.946131587681838*^9}, {
   3.946133008470138*^9, 3.9461330148422537`*^9}, {3.9463517981653223`*^9, 
   3.946351804030137*^9}, {3.9463700723395777`*^9, 3.9463700739336033`*^9}, {
   3.946370115650092*^9, 3.946370127409975*^9}, {3.958038637773816*^9, 
