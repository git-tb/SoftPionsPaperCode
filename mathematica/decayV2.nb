Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Integrand", "[", 
    RowBox[{"t_", ",", "v_", ",", "p_"}], "]"}], "=", 
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"ustar", "[", 
       RowBox[{"t", ",", "v", ",", "p"}], "]"}], ">", "1"}], ",", 
     RowBox[{
      RowBox[{"primespecfunc", "[", 
       RowBox[{"Q", "*", "t"}], "]"}], "*", 
      FractionBox["1", 
       SqrtBox[
        RowBox[{
         SuperscriptBox[
          RowBox[{"ustar", "[", 
           RowBox[{"t", ",", "v", ",", "p"}], "]"}], "2"], "-", "1"}]]], "*", 
      
      FractionBox["1", 
       SqrtBox[
        RowBox[{"1", "-", 
         SuperscriptBox["v", "2"]}]]], "*", 
      FractionBox["t", 
       RowBox[{
        RowBox[{"w", "[", 
         RowBox[{"p", ",", "ma"}], "]"}], "*", 
        RowBox[{"w", "[", 
         RowBox[{
          RowBox[{"t", "*", "Q"}], ",", "mb"}], "]"}]}]]}], ",", "0"}], 
    "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"MyIntegral", "[", "p_", "]"}], ":=", 
   RowBox[{
    FractionBox[
     RowBox[{"ma", "*", "B", "*", 
      SuperscriptBox["Q", "2"]}], 
     RowBox[{"p", "*", "\[Pi]"}]], "*", 
    RowBox[{
     RowBox[{
      RowBox[{"Cuhre", "[", 
       RowBox[{
        RowBox[{"Integrand", "[", 
         RowBox[{"t", ",", "v", ",", "p"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"t", ",", 
          RowBox[{"LowerBoundT", "[", "p", "]"}], ",", 
          RowBox[{"tmax", "[", "p", "]"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"v", ",", 
          RowBox[{"BetterLowerBoundV", "[", 
           RowBox[{"t", ",", "p"}], "]"}], ",", "1"}], "}"}], ",", 
        RowBox[{"Verbose", "->", "0"}]}], "]"}], "[", 
      RowBox[{"[", "1", "]"}], "]"}], "[", 
     RowBox[{"[", "1", "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"pTstest", "=", 
