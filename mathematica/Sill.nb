Cell[BoxData[{
 RowBox[{
  RowBox[{"invProp", "=", 
   RowBox[{
    RowBox[{"-", "s"}], "+", 
    RowBox[{"M", "^", "2"}], "-", 
    RowBox[{"I", "*", "\[CapitalGamma]", "*", "M"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Solve", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"Im", "[", "invProp", "]"}], "==", "0"}], ",", 
     RowBox[{
      RowBox[{"Re", "[", "invProp", "]"}], "==", "0"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"M", ",", "\[CapitalGamma]"}], "}"}], ",", 
   RowBox[{"Assumptions", "->", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Mp", "\[Element]", "Reals"}], ",", 
      RowBox[{"\[CapitalGamma]p", "\[Element]", "Reals"}], ",", 
      RowBox[{"\[CapitalGamma]", "\[Element]", "Reals"}], ",", 
      RowBox[{"M", "\[Element]", "Reals"}]}], "}"}]}]}], "]"}]}], "Input",
