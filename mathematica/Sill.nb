Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"LHS", "=", 
  RowBox[{"Expand", "[", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"M", "^", "2"}], "-", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"Mp", "-", 
         RowBox[{"I", "*", 
          RowBox[{"\[CapitalGamma]p", "/", "2"}]}]}], ")"}], "^", "2"}]}], 
     ")"}], "^", "2"}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"RHS", "=", 
  RowBox[{"Expand", "[", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"I", "*", "\[CapitalGamma]", "*", 
      RowBox[{"Sqrt", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "4"}], "*", 
         RowBox[{"m\[Pi]", "^", "2"}]}], "+", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"Mp", "-", 
           RowBox[{"I", "*", 
            RowBox[{"\[CapitalGamma]p", "/", "2"}]}]}], ")"}], "^", "2"}]}], 
       "]"}]}], ")"}], "^", "2"}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"sols", "=", 
  RowBox[{
   RowBox[{"Solve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"Im", "[", "LHS", "]"}], "==", 
        RowBox[{"Im", "[", "RHS", "]"}]}], ",", 
       RowBox[{
        RowBox[{"Re", "[", "LHS", "]"}], "==", 
        RowBox[{"Re", "[", "RHS", "]"}]}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"M", ",", "\[CapitalGamma]"}], "}"}], ",", 
     RowBox[{"Assumptions", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"m\[Pi]", "\[Element]", "Reals"}], ",", 
        RowBox[{"Mp", "\[Element]", "Reals"}], ",", 
        RowBox[{"\[CapitalGamma]p", "\[Element]", "Reals"}], ",", 
        RowBox[{"\[CapitalGamma]", "\[Element]", "Reals"}], ",", 
        RowBox[{"M", "\[Element]", "Reals"}]}], "}"}]}]}], "]"}], "//", 
   "FullSimplify"}]}], "\[IndentingNewLine]"}], "Input",
 CellChangeTimes->{{3.9748834437487993`*^9, 3.974883611244216*^9}, {
  3.9748836599499807`*^9, 3.974883680397954*^9}, {3.9748837385842533`*^9, 
