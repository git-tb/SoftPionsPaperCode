Cell[CellGroupData[{

Cell["Perform the dcc spec computation in Mathematica", "Section",
 CellChangeTimes->{{3.946379869625616*^9, 3.946379876679063*^9}, {
  3.946381404168169*^9, 3.94638140564287*^9}, {3.959155240014802*^9, 
  3.9591552448135757`*^9}},ExpressionUUID->"553ce2be-2e0a-468b-b50f-\
f598786da4af"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ComputeDCCSpec", "[", 
   RowBox[{"m_", ",", "ps_", ",", "f_", ",", "Df_", ",", "anti_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "\[Omega]s", ",", "J0rp", ",", "J1rp", ",", "Y0tw", ",", "Y1tw", ",", 
      "J0tw", ",", "J1tw", ",", "plusminus", ",", "G0", ",", "G1", ",", 
      "Jp"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"(*", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
      "f", " ", "is", " ", "supposed", " ", "to", " ", "be", " ", "the", " ", 
       "condensate", " ", "field"}], ",", " ", 
      RowBox[{"Df", " ", 
       RowBox[{"it", "'"}], "s", " ", "perpendicular", " ", "derivative"}], 
      ",", " ", "\[IndentingNewLine]", 
      RowBox[{"Df", " ", "=", " ", 
       RowBox[{
        RowBox[{
         RowBox[{"r", "'"}], "*", 
         RowBox[{"D", "[", 
          RowBox[{"f", ",", "\[Tau]"}], "]"}]}], "+", 
        RowBox[{
         RowBox[{"\[Tau]", "'"}], "*", 
         RowBox[{"D", "[", 
          RowBox[{"f", ",", "r"}], "]"}]}]}]}]}], "\[IndentingNewLine]", 
     "*)"}], "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"GeVtoIfm", "=", "5.0677"}], ";", 
     RowBox[{"(*", 
      RowBox[{"5.0677", ";"}], 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"1", "GeV"}], "=", 
        RowBox[{"5.0677", 
         RowBox[{"(", 
          RowBox[{"fm", "^", 
           RowBox[{"-", "1"}]}], ")"}], 
         RowBox[{"\\[", "hbar", "]"}], "c"}]}], "*)"}], "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{"IfmtoGeV", "=", 
      RowBox[{"1", "/", "GeVtoIfm"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"fmtoIGeV", "=", "GeVtoIfm"}], ";", "\[IndentingNewLine]", 
     RowBox[{"IGeVtofm", "=", 
      RowBox[{"1", "/", "fmtoIGeV"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"\[Omega]s", "=", 
      RowBox[{"Sqrt", "[", 
       RowBox[{
        RowBox[{"ps", "^", "2"}], "+", 
        RowBox[{"m", "^", "2"}]}], "]"}]}], ";", 
     RowBox[{"(*", 
      RowBox[{"in", " ", "GeV", " ", 
       RowBox[{"(", 
        RowBox[{"p", " ", "in", " ", "GeV"}], ")"}]}], " ", "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"J0rp", "[", "\[Alpha]_", "]"}], "=", 
      RowBox[{"BesselJ", "[", 
       RowBox[{"0", ",", 
        RowBox[{
         RowBox[{"r", "[", "\[Alpha]", "]"}], "*", "ps", "*", "GeVtoIfm"}]}], 
       "]"}]}], ";", 
     RowBox[{"(*", "dimensionless", "*)"}], "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"J1rp", "[", "\[Alpha]_", "]"}], "=", 
      RowBox[{"BesselJ", "[", 
       RowBox[{"1", ",", 
        RowBox[{
         RowBox[{"r", "[", "\[Alpha]", "]"}], "*", "ps", "*", "GeVtoIfm"}]}], 
       "]"}]}], ";", 
     RowBox[{"(*", "dimensionless", "*)"}], "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Y0tw", "[", "\[Alpha]_", "]"}], "=", 
      RowBox[{"BesselY", "[", 
       RowBox[{"0", ",", 
        RowBox[{
         RowBox[{"\[Tau]", "[", "\[Alpha]", "]"}], "*", "\[Omega]s", "*", 
         "GeVtoIfm"}]}], "]"}]}], ";", 
     RowBox[{"(*", "dimensionless", "*)"}], "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Y1tw", "[", "\[Alpha]_", "]"}], "=", 
      RowBox[{"BesselY", "[", 
       RowBox[{"1", ",", 
        RowBox[{
         RowBox[{"\[Tau]", "[", "\[Alpha]", "]"}], "*", "\[Omega]s", "*", 
         "GeVtoIfm"}]}], "]"}]}], ";", 
     RowBox[{"(*", "dimensionless", "*)"}], "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"J0tw", "[", "\[Alpha]_", "]"}], "=", 
      RowBox[{"BesselJ", "[", 
       RowBox[{"0", ",", 
        RowBox[{
         RowBox[{"\[Tau]", "[", "\[Alpha]", "]"}], "*", "\[Omega]s", "*", 
         "GeVtoIfm"}]}], "]"}]}], ";", 
     RowBox[{"(*", "dimensionless", "*)"}], "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"J1tw", "[", "\[Alpha]_", "]"}], "=", 
      RowBox[{"BesselJ", "[", 
       RowBox[{"1", ",", 
        RowBox[{
         RowBox[{"\[Tau]", "[", "\[Alpha]", "]"}], "*", "\[Omega]s", "*", 
         "GeVtoIfm"}]}], "]"}]}], ";", 
     RowBox[{"(*", "dimensionless", "*)"}], "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"plusminus", "=", 
      RowBox[{"If", "[", 
       RowBox[{"anti", ",", 
        RowBox[{"-", "1"}], ",", 
        RowBox[{"+", "1"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"G0", "[", "\[Alpha]_", "]"}], "=", 
      RowBox[{
       RowBox[{"J0rp", "[", "\[Alpha]", "]"}], "*", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", 
          RowBox[{"Y0tw", "[", "\[Alpha]", "]"}]}], "+", 
         RowBox[{"plusminus", "*", "I", "*", 
          RowBox[{"J0tw", "[", "\[Alpha]", "]"}]}]}], ")"}]}]}], ";", 
     RowBox[{"(*", "dimensionless", "*)"}], "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"G1", "[", "\[Alpha]_", "]"}], "=", 
      RowBox[{
       RowBox[{
        RowBox[{"D\[Tau]", "[", "\[Alpha]", "]"}], "*", "fmtoIGeV", "*", "ps",
         "*", 
        RowBox[{"J1rp", "[", "\[Alpha]", "]"}], "*", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", 
           RowBox[{"Y0tw", "[", "\[Alpha]", "]"}]}], "+", 
          RowBox[{"plusminus", "*", "I", "*", 
           RowBox[{"J0tw", "[", "\[Alpha]", "]"}]}]}], ")"}]}], "+", 
       RowBox[{"(*", "dimensionless", "*)"}], "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Dr", "[", "\[Alpha]", "]"}], "*", "fmtoIGeV", "*", 
        "\[Omega]s", "*", 
        RowBox[{"J0rp", "[", "\[Alpha]", "]"}], "*", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", 
           RowBox[{"Y1tw", "[", "\[Alpha]", "]"}]}], "+", 
          RowBox[{"plusminus", "*", "I", "*", 
           RowBox[{"J1tw", "[", "\[Alpha]", "]"}]}]}], ")"}]}]}]}], ";", 
     RowBox[{"(*", "dimensionless", "*)"}], "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Jp", "=", 
      RowBox[{"2", "*", 
       RowBox[{"Pi", "^", "2"}], "*", 
       RowBox[{"NIntegrate", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"\[Tau]", "[", "\[Alpha]", "]"}], "*", 
          RowBox[{"r", "[", "\[Alpha]", "]"}], "*", 
          RowBox[{"fmtoIGeV", "^", "2"}], "*", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"Df", "[", "\[Alpha]", "]"}], "*", 
             RowBox[{"G0", "[", "\[Alpha]", "]"}]}], "+", 
            RowBox[{
             RowBox[{"f", "[", "\[Alpha]", "]"}], "*", 
             RowBox[{"G1", "[", "\[Alpha]", "]"}]}]}], ")"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"\[Alpha]", ",", "0", ",", 
           RowBox[{"\[Pi]", "/", "2"}]}], "}"}], ",", "\[IndentingNewLine]", 
         RowBox[{"Method", "->", 
          RowBox[{"{", 
           RowBox[{"Automatic", ",", 
            RowBox[{"\"\<SymbolicProcessing\>\"", "->", "0"}]}], "}"}]}]}], 
        "\[IndentingNewLine]", "]"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"0.5", "*", 
      RowBox[{
       RowBox[{
        RowBox[{"Abs", "[", "Jp", "]"}], "^", "2"}], "/", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"2", "*", "\[Pi]"}], ")"}], "^", "3"}]}]}]}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.946375513622485*^9, 3.94637562057373*^9}, 
   3.946375757011272*^9, {3.946375790437182*^9, 3.9463758147731667`*^9}, {
   3.946376801393381*^9, 3.946376801736206*^9}, {3.946376930554072*^9, 
   3.946376932668261*^9}, {3.9580391436775093`*^9, 3.9580391764477873`*^9}, {
   3.958039532284418*^9, 3.9580395939284887`*^9}, {3.958040635381761*^9, 
